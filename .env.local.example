# Production (Supabase cloud)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RACE_ADMIN_PASSWORD=your-admin-password

# For local development, run `supabase start` and create .env.development.local
# with the local URLs/keys printed by that command. Next.js will automatically
# use .env.development.local when running `pnpm dev`.
